# ══════════════════════════════════════════════════════════════════
#  Doc Agent — Environment Configuration
# ══════════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values:
#    cp .env.example .env

# ── VLM Backend (choose one) ──────────────────────────────────────
# gemini   → FREE, just needs Google account (recommended for students)
# claude   → Paid Anthropic API key required
# internvl → Local GPU model, no API key, needs Colab GPU runtime
# llava    → Local GPU model, no API key, needs Colab GPU runtime
VLM_BACKEND=gemini

# ── Google Gemini API Key (FREE) ──────────────────────────────────
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Sign in with your Google account
# 3. Click "Create API key"
# 4. Paste the key below
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# ── Anthropic Claude (optional, paid) ────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Tesseract OCR ─────────────────────────────────────────────────
# Linux/Colab:  tesseract  (auto-installed via apt)
# macOS:        /opt/homebrew/bin/tesseract
TESSERACT_CMD=tesseract
OCR_DPI=300

# ── Confidence Thresholds ─────────────────────────────────────────
EXTRACTION_CONF_THRESHOLD=0.70
AUTO_APPROVE_THRESHOLD=0.85
TOTAL_TOLERANCE=0.01
FUZZY_VENDOR_THRESHOLD=80
MAX_CORRECTION_ATTEMPTS=2

# ── Storage Paths ─────────────────────────────────────────────────
SQLITE_PATH=./data/invoices.db
CHROMA_PERSIST_DIR=./data/chroma
