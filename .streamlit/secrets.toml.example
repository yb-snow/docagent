# Streamlit Cloud secrets template — for public deployment only.
#
# Local dev does NOT use this file — it uses .env (see .env.example).
#
# On Streamlit Community Cloud: paste these keys into your app's
# "Settings > Secrets" dashboard (do not commit a real secrets.toml).
# If you want to test locally with this file instead of .env, copy it to
# .streamlit/secrets.toml — that path is gitignored.
#
# IMPORTANT — TOML ordering: any key defined AFTER a [section] header
# belongs to that section, not the top level, even across blank lines.
# FERNET_KEY must stay BEFORE the [auth] header below, or it silently
# becomes auth.FERNET_KEY instead of a top-level secret.

# ── Per-user API key encryption ───────────────────────────────────────────
# Each signed-in user enters their own Gemini/Claude key in Settings; it's
# encrypted with this key before being stored. Generate once and never
# rotate it casually — rotating invalidates every previously-saved key.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY = "generate-your-own-fernet-key-here"

# ── Google sign-in (st.login) ─────────────────────────────────────────────
# 1. Google Cloud Console → APIs & Services → Credentials →
#    Create OAuth Client ID → type "Web application".
# 2. Authorized redirect URIs — add both:
#      http://localhost:8501/oauth2callback   (local dev)
#      https://<your-app>.streamlit.app/oauth2callback   (deployed)
# 3. Paste the client ID/secret below.
[auth]
redirect_uri         = "http://localhost:8501/oauth2callback"
cookie_secret         = "generate-a-long-random-string-here"
client_id             = "your-client-id.apps.googleusercontent.com"
client_secret         = "your-google-client-secret"
server_metadata_url   = "https://accounts.google.com/.well-known/openid-configuration"
